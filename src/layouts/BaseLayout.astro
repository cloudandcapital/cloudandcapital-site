---
import '../styles/global.css';
import '../styles/type.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Cloud & Capital', description = '' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    {title && <title>{title}</title>}
    {description && <meta name="description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://cloudandcapital.com" />
    <meta property="og:title" content={title || 'Cloud & Capital'} />
    <meta property="og:description" content={description || 'FinOps tools and insights for cloud infrastructure teams'} />
    <meta property="og:image" content="https://cloudandcapital.com/images/og-image.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title || 'Cloud & Capital'} />
    <meta name="twitter:description" content={description || 'FinOps tools and insights for cloud infrastructure teams'} />
    <meta name="twitter:image" content="https://cloudandcapital.com/images/og-image.png" />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-GXRMNTEB3B"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-GXRMNTEB3B');
    </script>
  </head>
  <body>
    <style>
      .site-nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 200;
        padding: 1rem 2.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(245,238,233,.96);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        border-bottom: 1px solid rgba(0,0,0,.07);
      }
      .site-nav-logo {
        font-family: 'Cormorant Garamond', 'Georgia', serif;
        font-size: .95rem;
        font-weight: 500;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: #000;
        text-decoration: none;
      }
      .site-nav-links {
        display: flex;
        gap: 1.75rem;
        list-style: none;
        margin: 0; padding: 0;
        align-items: center;
      }
      .site-nav-links a {
        font-family: 'DM Mono', monospace;
        font-size: .58rem;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: #4A4A4A;
        text-decoration: none;
        transition: color .2s;
      }
      .site-nav-links a:hover { color: #000; }
      .site-nav-dropdown { position: relative; }
      .site-nav-dropdown-btn {
        font-family: 'DM Mono', monospace;
        font-size: .58rem;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: #4A4A4A;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        display: flex;
        align-items: center;
        gap: .3rem;
        transition: color .2s;
      }
      .site-nav-dropdown-btn:hover { color: #000; }
      .site-nav-chevron { font-size: .48rem; display: inline-block; transition: transform .2s; }
      .site-nav-dropdown:hover .site-nav-chevron,
      .site-nav-dropdown.is-open .site-nav-chevron { transform: rotate(180deg); }
      .site-nav-dropdown-menu {
        display: none;
        position: absolute;
        top: calc(100% + .85rem);
        right: 0;
        background: #faf7f2;
        border: 1px solid rgba(0,0,0,.08);
        box-shadow: 0 8px 28px rgba(0,0,0,.08);
        list-style: none;
        padding: .4rem 0;
        min-width: 168px;
        z-index: 210;
      }
      .site-nav-dropdown:hover .site-nav-dropdown-menu,
      .site-nav-dropdown:focus-within .site-nav-dropdown-menu,
      .site-nav-dropdown.is-open .site-nav-dropdown-menu { display: block; }
      .site-nav-dropdown-menu li a {
        display: block;
        padding: .55rem 1.25rem;
        font-family: 'DM Mono', monospace;
        font-size: .58rem;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: #4A4A4A;
        text-decoration: none;
        transition: color .15s, background .15s;
        white-space: nowrap;
      }
      .site-nav-dropdown-menu li a:hover { color: #000; background: rgba(107,142,127,.07); }
      .site-nav-toggle {
        display: none;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 6px 4px;
        z-index: 201;
      }
      .site-nav-toggle span {
        display: block;
        width: 22px;
        height: 1.5px;
        background: #000;
        border-radius: 2px;
        transition: background .25s;
      }
      .site-nav-toggle.is-open span { background: rgba(244,239,230,.9); }
      @media (max-width: 768px) {
        .site-nav { padding: 1rem 1.25rem; }
        .site-nav-toggle { display: flex; z-index: 301; }
        .site-nav-links {
          display: none;
          position: absolute;
          top: 100%;
          left: 0;
          right: 0;
          background: #191714;
          flex-direction: column;
          align-items: flex-start;
          justify-content: flex-start;
          gap: 0;
          z-index: 300;
          list-style: none;
          padding: .75rem 0 1.25rem;
          max-height: calc(100vh - 60px);
          overflow-y: auto;
          border-top: 1px solid rgba(255,255,255,.06);
          box-shadow: 0 12px 32px rgba(0,0,0,.35);
        }
        .site-nav-links.is-open { display: flex; }
        .site-nav-links > li { width: 100%; }
        .site-nav-links a {
          display: block;
          padding: .8rem 1.75rem;
          font-size: .68rem;
          letter-spacing: .16em;
          color: rgba(244,239,230,.65);
        }
        .site-nav-links a:hover { color: rgba(244,239,230,1); }
        .site-nav-dropdown { width: 100%; }
        .site-nav-dropdown-btn { display: block; width: 100%; padding: .8rem 1.75rem; text-align: left; color: rgba(244,239,230,.65); font-size: .68rem; letter-spacing: .16em; }
        .site-nav-dropdown-btn:hover { color: rgba(244,239,230,1); }
        .site-nav-dropdown-menu { position: static; background: rgba(255,255,255,.04); border: none; box-shadow: none; padding: .25rem 0; min-width: 0; text-align: left; }
        .site-nav-dropdown-menu li a { padding: .6rem 1.75rem .6rem 2.75rem; color: rgba(244,239,230,.42); font-size: .63rem; background: transparent; }
        .site-nav-dropdown-menu li a:hover { color: rgba(244,239,230,.85); background: transparent; }
      }
    </style>
    <nav class="site-nav">
      <a class="site-nav-logo" href="/">Cloud &amp; Capital</a>
      <button class="site-nav-toggle" aria-label="Open menu" aria-expanded="false" id="tool-nav-toggle">
        <span></span><span></span><span></span>
      </button>
      <ul class="site-nav-links" id="tool-nav-links">
        <li><a href="/#discipline">Discipline</a></li>
        <li><a href="/#work">Work</a></li>
        <li><a href="/#about">About</a></li>
        <li><a href="/#community">Community</a></li>
        <li><a href="/#writing">Writing</a></li>
        <li class="site-nav-dropdown" id="tool-nav-tools">
          <button class="site-nav-dropdown-btn" aria-haspopup="true" aria-expanded="false" id="tool-nav-tools-btn">Tools <span class="site-nav-chevron">▾</span></button>
          <ul class="site-nav-dropdown-menu">
            <li><a href="https://market-tape.cloudandcapital.com" target="_blank">Market Tape</a></li>
            <li><a href="/signal-audit">Signal Audit</a></li>
            <li><a href="/interactive-lab">Interactive Lab</a></li>
          </ul>
        </li>
      </ul>
    </nav>
    <script>
      (function() {
        var toggle = document.getElementById('tool-nav-toggle');
        var links = document.getElementById('tool-nav-links');
        if (!toggle || !links) return;
        toggle.addEventListener('click', function() {
          var isOpen = links.classList.toggle('is-open');
          toggle.classList.toggle('is-open', isOpen);
          toggle.setAttribute('aria-expanded', isOpen);
          document.body.style.overflow = isOpen ? 'hidden' : '';
        });
        links.querySelectorAll('a').forEach(function(a) {
          a.addEventListener('click', function() {
            links.classList.remove('is-open');
            toggle.classList.remove('is-open');
            toggle.setAttribute('aria-expanded', 'false');
            document.body.style.overflow = '';
          });
        });
      })();
      (function() {
        var btn = document.getElementById('tool-nav-tools-btn');
        var item = document.getElementById('tool-nav-tools');
        if (!btn || !item) return;
        btn.addEventListener('click', function(e) {
          e.stopPropagation();
          var isOpen = item.classList.toggle('is-open');
          btn.setAttribute('aria-expanded', isOpen);
        });
        document.addEventListener('click', function() {
          item.classList.remove('is-open');
          btn.setAttribute('aria-expanded', 'false');
        });
      })();
    </script>
    <slot />
  </body>
</html>
