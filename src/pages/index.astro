---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Cloud & Capital" description="Decision systems for finance and engineering leaders.">
  <main>
    <h1 class="display">Cloud & Capital</h1>
    <p class="tagline body">Decision systems for finance and engineering leaders.</p>
  </main>
</BaseLayout>

<style>
  main {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 2rem;
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 400;
    color: var(--forest-deep);
    letter-spacing: -0.01em;
    text-align: center;
  }

  .tagline {
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-style: italic;
    color: var(--text-muted);
    text-align: center;
  }
</style>
