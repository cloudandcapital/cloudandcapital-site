.cdb{position:relative;width:100%;height:200px;background:#fff;overflow:hidden;isolation:isolate;}
.cdb-grid{position:absolute;inset:0;background-image:linear-gradient(to bottom,rgba(90,126,94,.14) 1px,transparent 1px);background-size:100% 28px;animation:cdbgs 6s linear infinite;z-index:1;}
@keyframes cdbgs{from{background-position:0 0}to{background-position:0 28px}}
.cdb-ticks{position:absolute;inset:0;background-image:repeating-linear-gradient(to right,rgba(90,126,94,.1) 0 1px,transparent 1px 120px);animation:cdbts 12s linear infinite;z-index:1;}
@keyframes cdbts{from{background-position:0 0}to{background-position:-120px 0}}
.cdb-chart{position:absolute;inset:0;width:100%;height:100%;z-index:2;pointer-events:none;}
.cdb-ct{transform-box:view-box;animation:cdbsc linear infinite;}
.cdb-ct1{animation-duration:14s}.cdb-ct2{animation-duration:22s}.cdb-ct3{animation-duration:18s}
@keyframes cdbsc{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.cdb-tr{fill:none;stroke:#5A7E5E;stroke-linejoin:round;stroke-linecap:round;vector-effect:non-scaling-stroke;}
.cdb-tr.cdb-ct1{stroke-width:1.6;stroke-opacity:.45}.cdb-tr.cdb-ct2{stroke-width:1.2;stroke-opacity:.32;stroke-dasharray:3 4}.cdb-tr.cdb-ct3{stroke-width:1.4;stroke-opacity:.38}
.cdb-pulse{position:absolute;right:2%;top:54%;width:8px;height:8px;margin:-4px;background:#5A7E5E;border-radius:50%;box-shadow:0 0 0 0 rgba(90,126,94,.55);animation:cdbpa 1.8s ease-out infinite;z-index:3;}
@keyframes cdbpa{0%{box-shadow:0 0 0 0 rgba(90,126,94,.55);opacity:1}70%{box-shadow:0 0 0 12px rgba(90,126,94,0);opacity:.8}100%{box-shadow:0 0 0 0 rgba(90,126,94,0);opacity:1}}
.cdb-floats{position:absolute;inset:0;z-index:3;pointer-events:none;}
.cdb-fl{position:absolute;font-family:'DM Mono',monospace;letter-spacing:.06em;opacity:0;white-space:nowrap;transform:translate(-50%,-50%);animation:cdbff 8s ease-in-out infinite;}
.cdb-fl-s{font-size:.7rem;color:rgba(90,126,94,.55)}.cdb-fl-m{font-size:.85rem;color:rgba(90,126,94,.7)}.cdb-fl-l{font-size:1rem;color:rgba(90,126,94,.85);font-weight:500}
@keyframes cdbff{0%,100%{opacity:0;transform:translate(-50%,-40%)}15%{opacity:1;transform:translate(-50%,-50%)}55%{opacity:1;transform:translate(-50%,-50%)}75%{opacity:0;transform:translate(-50%,-60%)}}
.cdb-q{display:none;}
.cdb-qi{max-width:1000px;text-align:center;padding:.6rem 2.4rem;background:radial-gradient(ellipse 100% 180% at 50% 50%,rgba(255,255,255,.96) 0%,rgba(255,255,255,.9) 40%,rgba(255,255,255,.55) 75%,rgba(255,255,255,0) 100%);}
.cdb-qt{font-family:'Cormorant Garamond',serif;font-style:italic;font-weight:400;font-size:clamp(1.05rem,1.6vw,1.6rem);line-height:1.4;color:#5A7E5E;margin:0;}
.cdb-em{font-weight:500;color:#304D35}
.cdb-qm{font-family:'Cormorant Garamond',serif;font-style:italic;color:rgba(90,126,94,.35);font-size:1.4em;line-height:1;vertical-align:-.18em;padding:0 .12em;}
.cdb-ch{position:absolute;z-index:4;font-family:'DM Mono',monospace;font-size:.58rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(90,126,94,.7);pointer-events:none;}
.cdb-ch.tl{top:.7rem;left:1.2rem}.cdb-ch.tr{top:.7rem;right:1.2rem}.cdb-ch.bl{bottom:.7rem;left:1.2rem}.cdb-ch.br{bottom:.7rem;right:1.2rem}
.cdb-ld{display:inline-block;width:5px;height:5px;border-radius:50%;background:#5A7E5E;vertical-align:middle;margin-right:.5rem;animation:cdbbl 1.5s ease-in-out infinite;}
