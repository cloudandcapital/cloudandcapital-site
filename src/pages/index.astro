<script is:inline>
// Quote animation
(function(){
  var words = document.querySelectorAll('.fq-text span');
  var section = document.getElementById('fq-section');
  if(!section) return;
  var triggered = false;
  var qObs = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting && !triggered){
        triggered = true;
        section.classList.add('fq-active');
        words.forEach(function(w,i){ setTimeout(function(){ w.classList.add('fq-visible'); }, 300 + i*55); });
      }
    });
  },{threshold:0.35});
  qObs.observe(section);
})();

(function(){
  var s=document.getElementById('fq-section');
  var words=document.querySelectorAll('.fq-text span');
  if(!s||!words.length)return;
  var done=false;
  new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting&&!done){
        done=true;s.classList.add('fq-active');
        words.forEach(function(w,i){setTimeout(function(){w.classList.add('fq-visible');},300+i*55);});
      }
    });
  },{threshold:0.35}).observe(s);
})();
// Scroll reveal
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); });
}, {threshold:.08});
document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

// Photo carousel
let pos = 0;
const track = document.getElementById('ph-track');
const getSlides = () => track ? track.querySelectorAll('.photo-slide') : [];
const slideW = () => { const s = getSlides(); return s.length ? s[0].offsetWidth + 16 : 0; };
const phNext = document.getElementById('ph-next');
const phPrev = document.getElementById('ph-prev');
if (phNext) phNext.addEventListener('click', () => {
  const max = getSlides().length - 3;
  if(pos < max){ pos++; track.style.transform = `translateX(-${pos * slideW()}px)`; }
});
if (phPrev) phPrev.addEventListener('click', () => {
  if(pos > 0){ pos--; track.style.transform = `translateX(-${pos * slideW()}px)`; }
});

// Animated market chart
(function(){
  const canvas = document.getElementById('market-canvas');
  if(!canvas) return;
  const ctx = canvas.getContext('2d');
  let W, H, points = [], frame = 0, ticker = 142.35;

  function resize(){
    W = canvas.width = canvas.offsetWidth;
    H = canvas.height = canvas.offsetHeight;
    generatePoints();
  }

  function generatePoints(){
    points = [];
    let y = H * 0.15;
    let x = 0;
    while(x <= W + 60){
      const progress = x / (W + 80);
      const trendY = H * (0.15 + 0.63 * progress);
      const vol = H * 0.055 * (1 - progress * 0.4);
      y = y * 0.82 + trendY * 0.18 + (Math.random() - 0.5) * vol * 2;
      y = Math.max(H * 0.08, Math.min(H * 0.88, y));
      points.push({x, y});
      x += 36 + Math.random() * 18;
    }
  }

  let lastFrameTime = 0;
  let pausing = false, pauseUntil = 0;

  function draw(ts){
    requestAnimationFrame(draw);
    if(!W) return;
    // throttle: advance frame only every 80ms (~12fps for smooth slow draw)
    if(pausing){ if(ts < pauseUntil) return; pausing = false; frame = 0; generatePoints(); ticker = 142.35 + (Math.random()-0.5)*3; }
    if(ts - lastFrameTime < 80) return;
    lastFrameTime = ts;

    ctx.clearRect(0,0,W,H);
    // grid lines
    ctx.strokeStyle = 'rgba(255,255,255,0.04)';
    ctx.lineWidth = 1;
    for(let gx=0;gx<W;gx+=W/6){ ctx.beginPath();ctx.moveTo(gx,0);ctx.lineTo(gx,H);ctx.stroke(); }
    for(let gy=0;gy<H;gy+=H/5){ ctx.beginPath();ctx.moveTo(0,gy);ctx.lineTo(W,gy);ctx.stroke(); }
    if(points.length < 2) return;

    const visible = Math.min(points.length, Math.floor(frame)+2);
    const pts = points.slice(0, visible);

    // gradient fill
    const grad = ctx.createLinearGradient(0,0,0,H);
    grad.addColorStop(0,'rgba(90,126,94,0.2)');
    grad.addColorStop(1,'rgba(90,126,94,0)');
    ctx.beginPath();
    ctx.moveTo(pts[0].x, pts[0].y);
    for(let i=1;i<pts.length;i++){
      const mx=(pts[i-1].x+pts[i].x)/2, my=(pts[i-1].y+pts[i].y)/2;
      ctx.quadraticCurveTo(pts[i-1].x,pts[i-1].y,mx,my);
    }
    ctx.lineTo(pts[pts.length-1].x,H);
    ctx.lineTo(pts[0].x,H);
    ctx.closePath();
    ctx.fillStyle=grad; ctx.fill();

    // price line
    ctx.beginPath();
    ctx.moveTo(pts[0].x,pts[0].y);
    for(let i=1;i<pts.length;i++){
      const mx=(pts[i-1].x+pts[i].x)/2, my=(pts[i-1].y+pts[i].y)/2;
      ctx.quadraticCurveTo(pts[i-1].x,pts[i-1].y,mx,my);
    }
    ctx.strokeStyle='#5A7E5E'; ctx.lineWidth=1.5; ctx.stroke();

    // end dot pulse
    const last = pts[pts.length-1];
    ctx.beginPath(); ctx.arc(last.x,last.y,3,0,Math.PI*2);
    ctx.fillStyle='#74A079'; ctx.fill();

    // update ticker label occasionally
    if(frame % 4 === 0){
      ticker += (Math.random()-0.49)*0.4;
      const el=document.getElementById('hvl-val');
      if(el) el.textContent = ticker.toFixed(2)+' ▼';
    }

    frame += 0.5; // half-speed advance
    if(frame >= points.length){ pausing=true; pauseUntil=ts+2800; } // 2.8s pause at end
  }

  window.addEventListener('resize', resize);
  resize();
  requestAnimationFrame(draw);
})();

// Animate stat numbers on scroll
const statNums = document.querySelectorAll('.s-num');
const statObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if(e.isIntersecting){
      e.target.style.opacity = '0';
      e.target.style.transform = 'translateY(10px)';
      setTimeout(() => {
        e.target.style.transition = 'opacity .5s ease, transform .5s ease';
        e.target.style.opacity = '1';
        e.target.style.transform = 'translateY(0)';
      }, 100 + Array.from(statNums).indexOf(e.target) * 80);
      statObs.unobserve(e.target);
    }
  });
}, {threshold:.5});
statNums.forEach(n => statObs.observe(n));
</script>

</SiteLayout>
