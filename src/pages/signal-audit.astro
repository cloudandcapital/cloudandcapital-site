---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Cloud & AI Signal Audit — Cloud & Capital" description="12 questions. No email required. AI-written diagnosis personalized to your answers.">

<style is:global>
  body {
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    line-height: 1.7;
    min-height: 100vh;
  }

  /* HERO */
  .hero {
    padding: 80px 60px 60px;
    max-width: 820px;
  }

  .label {
    font-family: 'Jost', sans-serif;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 28px;
  }

  .label::before {
    content: '';
    display: block;
    width: 36px;
    height: 1px;
    background: var(--text-muted);
  }

  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(38px, 5vw, 58px);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin-bottom: 24px;
    color: var(--text);
  }

  .hero h1 em { font-style: italic; color: var(--forest); }

  .hero p {
    font-size: 15px;
    color: var(--text-muted);
    max-width: 560px;
    line-height: 1.75;
    margin-bottom: 12px;
  }

  .meta-row {
    display: flex;
    gap: 32px;
    margin-top: 36px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }

  .meta-item {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-light);
  }

  .meta-item strong {
    display: block;
    font-size: 13px;
    letter-spacing: 0;
    text-transform: none;
    color: var(--text-muted);
    font-weight: 400;
    margin-top: 3px;
  }

  /* AUDIT CONTAINER */
  .audit-wrap {
    padding: 0 60px 100px;
    max-width: 900px;
  }

  .audit-card {
    background: var(--soft-white);
    border-radius: 3px;
    padding: 56px 56px 48px;
    box-shadow: var(--shadow-card);
    position: relative;
  }

  .audit-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--forest);
    border-radius: 3px 3px 0 0;
  }

  /* PROGRESS */
  .progress-bar-wrap {
    margin-bottom: 48px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .progress-track {
    flex: 1;
    height: 2px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--forest);
    border-radius: 2px;
    transition: width 0.5s cubic-bezier(0.4,0,0.2,1);
    width: 0%;
  }

  .progress-text {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-light);
    white-space: nowrap;
  }

  /* QUESTION CARD */
  .question-card { display: none; animation: fadeUp 0.4s ease forwards; }
  .question-card.active { display: block; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .q-number {
    font-family: 'Playfair Display', serif;
    font-size: 72px;
    font-weight: 400;
    color: var(--border);
    line-height: 1;
    margin-bottom: -16px;
    letter-spacing: -0.03em;
    user-select: none;
  }

  .q-category {
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--forest);
    margin-bottom: 12px;
  }

  .q-text {
    font-family: 'Playfair Display', serif;
    font-size: clamp(20px, 2.5vw, 26px);
    font-weight: 400;
    line-height: 1.35;
    color: var(--text);
    margin-bottom: 8px;
  }

  .q-sub {
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 36px;
    line-height: 1.6;
  }

  /* OPTIONS */
  .options { display: grid; gap: 10px; margin-bottom: 48px; }

  .option {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 20px 24px;
    border: 1px solid var(--border-soft);
    border-radius: 2px;
    cursor: pointer;
    transition: all 0.2s ease;
    background: var(--pure-white);
    text-align: left;
  }

  .option:hover { border-color: var(--forest); background: var(--pure-white); transform: translateX(2px); }

  .option.selected {
    border-color: var(--forest);
    background: var(--sage-tint);
    border-width: 1px;
    box-shadow: inset 3px 0 0 var(--forest);
  }

  .option-marker {
    width: 18px; height: 18px;
    border-radius: 50%;
    border: 1.5px solid var(--border-strong);
    flex-shrink: 0;
    margin-top: 2px;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .option.selected .option-marker { border-color: var(--forest); background: var(--forest); }
  .option.selected .option-marker::after { content: ''; width: 7px; height: 7px; border-radius: 50%; background: white; }

  .option-text { font-size: 14px; color: var(--text); line-height: 1.55; font-weight: 300; }

  .option-score {
    margin-left: auto;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--text-light);
    padding-left: 16px;
    flex-shrink: 0;
    font-style: italic;
  }

  /* NAV BUTTONS */
  .nav-buttons { display: flex; align-items: center; justify-content: space-between; }

  .btn {
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 14px 28px;
    border: 1px solid;
    cursor: pointer;
    transition: all 0.2s;
    font-weight: 400;
  }

  .btn-primary { background: var(--forest); color: white; border-color: var(--forest); }
  .btn-primary:hover { background: var(--forest-deep); border-color: var(--forest-deep); }
  .btn-primary:disabled { opacity: 0.35; cursor: not-allowed; }
  .btn-ghost { background: transparent; color: var(--text-muted); border-color: var(--border-strong); }
  .btn-ghost:hover { color: var(--text); border-color: var(--text-muted); }

  /* RESULTS */
  #results { display: none; animation: fadeUp 0.5s ease forwards; }

  .result-header {
    background: var(--near-black);
    color: white;
    padding: 64px 60px;
    margin: 0 -60px 60px;
  }

  .tier-label {
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .tier-label::before { content: ''; display: block; width: 36px; height: 1px; background: rgba(255,255,255,0.25); }

  .result-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 400;
    line-height: 1.15;
    margin-bottom: 16px;
  }

  .result-header h2 em { font-style: italic; color: var(--gold); }

  .score-display {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-top: 32px;
    padding-top: 28px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .score-num { font-family: 'Playfair Display', serif; font-size: 52px; font-weight: 400; color: white; line-height: 1; }
  .score-denom { font-size: 20px; color: rgba(255,255,255,0.35); }
  .score-label { margin-left: 20px; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.4); }

  /* TIER BANDS */
  .tier-bands { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; margin-top: 28px; }
  .tier-band { height: 3px; background: rgba(255,255,255,0.12); position: relative; }
  .tier-band.active { background: var(--gold); }
  .tier-band-label { font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.3); margin-top: 8px; }

  /* DIAGNOSIS */
  .diagnosis-section { margin-bottom: 60px; }

  .diagnosis-label {
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-light);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .diagnosis-label::before { content: ''; display: block; width: 36px; height: 1px; background: var(--text-light); }

  .diagnosis-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 19px;
    font-weight: 300;
    line-height: 1.8;
    color: var(--text);
    max-width: 680px;
    min-height: 120px;
  }

  .diagnosis-text .cursor {
    display: inline-block;
    width: 2px; height: 1em;
    background: var(--forest);
    margin-left: 2px;
    vertical-align: text-bottom;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

  /* SIGNAL BREAKDOWN */
  .breakdown { border-top: 1px solid var(--border); padding-top: 48px; margin-top: 48px; }

  .breakdown-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 32px; }

  .breakdown-item {
    padding: 28px 24px;
    background: var(--soft-white);
    border-radius: 3px;
    box-shadow: var(--shadow-card);
  }

  .breakdown-item-label { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-light); margin-bottom: 8px; }
  .breakdown-item-score { font-family: 'Playfair Display', serif; font-size: 28px; font-weight: 400; color: var(--text); line-height: 1; margin-bottom: 6px; }
  .breakdown-item-name { font-size: 13px; color: var(--text-muted); line-height: 1.4; }

  .breakdown-bar { height: 2px; background: var(--border); margin-top: 14px; border-radius: 2px; overflow: hidden; }
  .breakdown-bar-fill { height: 100%; background: var(--forest); border-radius: 2px; transition: width 1s ease 0.3s; width: 0%; }

  /* PRIORITY FOCUS */
  .priority-section { margin-top: 48px; }

  .priority-card {
    background: var(--near-black);
    color: white;
    padding: 44px 48px 40px;
    border-radius: 2px;
    margin-top: 24px;
    position: relative;
    overflow: hidden;
  }

  .priority-card::before { content: ''; position: absolute; top: 0; left: 0; width: 3px; height: 100%; background: var(--gold); }

  .priority-domain {
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .priority-domain::before { content: ''; display: block; width: 36px; height: 1px; background: var(--gold); }

  .priority-title { font-family: 'Playfair Display', serif; font-size: clamp(22px, 2.2vw, 28px); font-weight: 400; line-height: 1.25; margin-bottom: 18px; color: white; }
  .priority-title em { font-style: italic; color: var(--gold); }
  .priority-why { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 300; line-height: 1.7; color: rgba(255,255,255,0.82); max-width: 620px; margin-bottom: 28px; }

  .priority-move { padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.12); }
  .priority-move-label { font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.5); margin-bottom: 10px; }
  .priority-move-text { font-size: 15px; line-height: 1.65; color: white; max-width: 620px; }

  /* CTA */
  .cta-section {
    background: var(--forest);
    color: white;
    padding: 52px;
    margin-top: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }

  .cta-text h3 { font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 400; margin-bottom: 8px; line-height: 1.3; }
  .cta-text p { font-size: 13px; color: rgba(255,255,255,0.6); line-height: 1.6; }

  .btn-white { background: white; color: var(--forest); border-color: white; white-space: nowrap; text-decoration: none; display: inline-block; }
  .btn-white:hover { background: var(--cream); border-color: var(--cream); }

  /* LOADING */
  .loading-indicator {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-light);
    margin-bottom: 20px;
  }

  .loading-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--forest); animation: pulse 1.4s ease infinite; }
  .loading-dot:nth-child(2) { animation-delay: 0.2s; }
  .loading-dot:nth-child(3) { animation-delay: 0.4s; }

  @keyframes pulse { 0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; } 40% { transform: scale(1); opacity: 1; } }

  /* RESTART */
  .restart-btn {
    background: none;
    border: none;
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-light);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
    margin-top: 40px;
    display: inline-block;
  }

  .restart-btn:hover { color: var(--text); }

  @media (max-width: 768px) {
    .hero { padding: 48px 24px 40px; }
    .audit-wrap { padding: 0 24px 80px; }
    .audit-card { padding: 36px 24px 32px; }
    .result-header { padding: 48px 24px; margin: 0 -24px 40px; }
    .breakdown-grid { grid-template-columns: 1fr; }
    .tier-bands { display: none; }
    .cta-section { flex-direction: column; padding: 36px 24px; }
    .meta-row { flex-wrap: wrap; gap: 16px; }
  }
</style>

<!-- HERO -->
<div class="hero">
  <div class="label">Interactive · Diagnostic</div>
  <h1>The Cloud & AI<br><em>Signal Audit</em></h1>
  <p>Most organizations have cost data. The question is how far upstream it travels — and whether it arrives before decisions are already locked.</p>
  <p>12 questions. No email required. Results are personalized to your answers.</p>
  <div class="meta-row">
    <div class="meta-item">Format<strong>12 questions</strong></div>
    <div class="meta-item">Time<strong>5 minutes</strong></div>
    <div class="meta-item">Output<strong>AI-written diagnosis</strong></div>
    <div class="meta-item">Gate<strong>No sign-up</strong></div>
  </div>
</div>

<!-- AUDIT -->
<div class="audit-wrap">

  <!-- PROGRESS -->
  <div class="progress-bar-wrap" id="progressWrap">
    <div class="progress-track">
      <div class="progress-fill" id="progressFill"></div>
    </div>
    <div class="progress-text" id="progressText">1 of 12</div>
  </div>

  <!-- QUESTIONS -->
  <div class="audit-card" id="auditCard">
    <div id="questionsContainer"></div>
  </div>

  <!-- RESULTS -->
  <div id="results">
    <div class="result-header">
      <div class="tier-label" id="tierLabel">Signal Maturity Assessment</div>
      <h2 id="tierTitle">—</h2>
      <div class="score-display">
        <div class="score-num" id="scoreNum">—</div>
        <div class="score-denom">/ 36</div>
        <div class="score-label">Signal Score</div>
      </div>
      <div class="tier-bands" id="tierBands">
        <div>
          <div class="tier-band" id="band1"></div>
          <div class="tier-band-label">Signal Lag · 0–12</div>
        </div>
        <div>
          <div class="tier-band" id="band2"></div>
          <div class="tier-band-label">Signal Transit · 13–24</div>
        </div>
        <div>
          <div class="tier-band" id="band3"></div>
          <div class="tier-band-label">Signal Integration · 25–36</div>
        </div>
      </div>
    </div>

    <div class="diagnosis-section">
      <div class="diagnosis-label">Your Diagnosis</div>
      <div class="loading-indicator" id="loadingIndicator">
        <div class="loading-dot"></div>
        <div class="loading-dot"></div>
        <div class="loading-dot"></div>
        <span>Analyzing your signal profile</span>
      </div>
      <div class="diagnosis-text" id="diagnosisText"></div>
    </div>

    <div class="breakdown">
      <div class="diagnosis-label">Signal Breakdown by Domain</div>
      <div class="breakdown-grid" id="breakdownGrid"></div>
    </div>

    <div class="priority-section">
      <div class="diagnosis-label">Your Priority Focus</div>
      <div class="priority-card">
        <div class="priority-domain" id="priorityDomain">—</div>
        <div class="priority-title" id="priorityTitle">—</div>
        <div class="priority-why" id="priorityWhy">—</div>
        <div class="priority-move">
          <div class="priority-move-label">Start here</div>
          <div class="priority-move-text" id="priorityMove">—</div>
        </div>
      </div>
    </div>

    <div class="cta-section">
      <div class="cta-text">
        <h3>Want to go deeper on your cost signal?</h3>
        <p>The Interactive Lab lets you frame a specific infrastructure or AI spend decision and get a structured economic analysis.</p>
      </div>
      <a href="/interactive-lab" class="btn btn-white">Explore the Lab →</a>
    </div>

    <button class="restart-btn" onclick="restartAudit()">Retake the audit</button>
  </div>

</div>

<script is:inline>
const questions = [
  { id: 1, category: "Signal Timing", text: "When does cost information first enter a new workload or project?", sub: "Think about the last significant infrastructure or AI initiative your team launched.", options: [{ text: "Before architecture is finalized — cost is modeled as part of the design", score: 3 }, { text: "During the build phase, when engineering is already making decisions", score: 2 }, { text: "After deployment, when the first invoice or report surfaces", score: 1 }, { text: "There's no consistent point — it varies or doesn't happen", score: 0 }], domain: "Timing" },
  { id: 2, category: "AI Spend Accountability", text: "Who owns accountability for AI and LLM inference costs in your organization?", sub: "Inference costs are ongoing and compound fast — they need a named owner.", options: [{ text: "A named person or team with a defined budget and forecast", score: 3 }, { text: "Engineering or DevOps broadly — no single owner", score: 2 }, { text: "No one specifically — it surfaces in the cloud bill", score: 1 }, { text: "This conversation hasn't happened yet", score: 0 }], domain: "AI Governance" },
  { id: 3, category: "Anomaly Detection", text: "How quickly does your team know when cloud or AI spend spikes unexpectedly?", sub: "A 100% cost spike on a Tuesday morning — when would you find out?", options: [{ text: "Within hours — automated alerts notify the right people immediately", score: 3 }, { text: "Within a few days — a recurring report catches it", score: 2 }, { text: "At month-end billing review — sometimes weeks later", score: 1 }, { text: "When someone notices something feels off, or a bill surprises us", score: 0 }], domain: "Detection" },
  { id: 4, category: "Finance–Engineering Alignment", text: "When finance and engineering discuss cloud costs, how aligned are they?", sub: "Do they share a model, or translate across separate systems after the fact?", options: [{ text: "They share the same cost model and review it together regularly", score: 3 }, { text: "They meet, but each team works from different data sources", score: 2 }, { text: "Finance sees the invoice, engineering sees utilization — rarely together", score: 1 }, { text: "They operate on entirely separate information", score: 0 }], domain: "Alignment" },
  { id: 5, category: "Commitment Decisions", text: "How are Reserved Instance, Savings Plan, or committed use decisions made?", sub: "Commitment decisions are high-stakes — the process behind them signals a lot about signal maturity.", options: [{ text: "With modeled analysis, explicit tradeoff review, and finance sign-off", score: 3 }, { text: "Based on usage trends and an engineer's best judgment", score: 2 }, { text: "Reactively — we noticed we were overpaying and made a change", score: 1 }, { text: "We haven't made these decisions systematically", score: 0 }], domain: "Commitments" },
  { id: 6, category: "AI Inference vs. Training", text: "How does your team distinguish between AI training costs and inference costs?", sub: "Training is a one-time capital event. Inference is continuous opex. They require different governance.", options: [{ text: "Tracked separately with different owners, budgets, and forecasts", score: 3 }, { text: "Understood conceptually, but tracked together in one line", score: 2 }, { text: "Not differentiated in our current tooling or reporting", score: 1 }, { text: "We haven't made this distinction yet", score: 0 }], domain: "AI Governance" },
  { id: 7, category: "Architecture as a Cost Input", text: "Does cost enter architecture decisions before commitments are made?", sub: "The further upstream cost lives, the more optionality teams retain.", options: [{ text: "Yes — cost modeling is part of design review and vendor selection", score: 3 }, { text: "Sometimes — when someone on the team thinks to raise it", score: 2 }, { text: "Rarely — cost is reviewed after deployment, not before", score: 1 }, { text: "Cost isn't part of the architecture conversation", score: 0 }], domain: "Timing" },
  { id: 8, category: "SaaS Governance", text: "How does your organization manage SaaS license sprawl?", sub: "Unused SaaS licenses are a quiet drain — how visible is it?", options: [{ text: "Active audit cadence with renewals reviewed against real usage data", score: 3 }, { text: "Renewals are reviewed, but usage data is incomplete or estimated", score: 2 }, { text: "Renewals happen automatically, rarely questioned", score: 1 }, { text: "No formal process — we pay for what we signed up for", score: 0 }], domain: "SaaS" },
  { id: 9, category: "Showback & Chargeback", text: "Do individual teams or business units see their own cloud cost contributions?", sub: "Accountability requires visibility — does it exist at the team level?", options: [{ text: "Full chargeback — teams own their spend with real budget accountability", score: 3 }, { text: "Showback exists, but it's informational — not tied to budgets", score: 2 }, { text: "Some teams have visibility; others don't", score: 1 }, { text: "Costs are pooled — no team-level view exists", score: 0 }], domain: "Accountability" },
  { id: 10, category: "Forecasting Confidence", text: "How confident is your organization in next month's cloud and AI cost forecast?", sub: "Not a guess, not a hope — a model with inputs.", options: [{ text: "High confidence — forecasts are built from structured, modeled inputs", score: 3 }, { text: "Moderate — we extrapolate from recent trends with some assumptions", score: 2 }, { text: "Low — it's largely estimated and frequently off", score: 1 }, { text: "We don't forecast at this granularity", score: 0 }], domain: "Forecasting" },
  { id: 11, category: "Signal Reach", text: "How far upstream does cost signal reach in your organization?", sub: "Where in the decision chain does cost information actually live?", options: [{ text: "Into architecture choices, vendor selection, and roadmap planning", score: 3 }, { text: "Into sprint planning and deployment decisions", score: 2 }, { text: "Into quarterly reviews and budget cycles", score: 1 }, { text: "Primarily into finance and month-end reports", score: 0 }], domain: "Timing" },
  { id: 12, category: "Leadership Visibility", text: "When does leadership see cost data relative to when decisions are made?", sub: "The final test of signal maturity: does cost inform decisions, or explain them?", options: [{ text: "Before commitments — cost is part of the conversation, not the conclusion", score: 3 }, { text: "During — cost surfaces mid-process and sometimes shifts direction", score: 2 }, { text: "After — cost appears in reviews of decisions already made", score: 1 }, { text: "Leadership doesn't regularly see cost data at this level", score: 0 }], domain: "Accountability" }
];

const domains = {
  "Timing": { questions: [1,7,11], label: "Signal Timing" },
  "AI Governance": { questions: [2,6], label: "AI Governance" },
  "Detection": { questions: [3], label: "Anomaly Detection" },
  "Alignment": { questions: [4], label: "Finance–Engineering Alignment" },
  "Commitments": { questions: [5], label: "Commitment Decisions" },
  "SaaS": { questions: [8], label: "SaaS Governance" },
  "Accountability": { questions: [9,12], label: "Accountability" },
  "Forecasting": { questions: [10], label: "Forecasting" }
};

const priorityActions = {
  "Timing": { domain: "Signal Timing · where cost enters the decision", title: "Push cost <em>upstream</em>", why: "Your cost signal is arriving after commitments are already locked. The single highest-leverage move isn't better reporting — it's shifting cost into the decision phase, not the review phase. Every architecture, vendor, and reservation decision is an opportunity that's passing without a cost lens on it.", move: "Make a cost estimate a required deliverable for any new infrastructure project. Not a fully modeled forecast — just a structured range, reviewed in design, before commitments compound." },
  "AI Governance": { domain: "AI Governance · inference and LLM spend", title: "Put a <em>name</em> on AI spend", why: "AI inference costs compound fast and quietly, and training vs. inference are fundamentally different economic profiles. Without a named owner and separate forecasting, this is where the biggest cost surprises of the next 12 months will show up — not in cloud infrastructure.", move: "Designate one person accountable for AI and LLM cost with a defined budget. Track inference separately from training, and separately from cloud infrastructure, starting with your next budget cycle." },
  "Detection": { domain: "Anomaly Detection · time-to-awareness", title: "Close the <em>detection gap</em>", why: "Delayed detection means spend spikes compound before anyone can act on them. Speed of awareness is speed of intervention — and right now, cost anomalies are reaching your team too slowly to matter.", move: "Set up automated alerts for cost deltas above a threshold you define. Route them to the team that can actually do something — engineers closest to the workload, not just finance at month-end." },
  "Alignment": { domain: "Finance–Engineering Alignment", title: "Build a <em>shared</em> cost language", why: "When finance and engineering work from different data sources, they're making different decisions and translating across the gap every time. That translation cost is invisible but enormous — it shows up as delayed responses, repeated analysis, and missed tradeoffs.", move: "Create one dashboard both teams actually use. Make it the source of truth for cost conversations, not a separate report for each side. Meet against it monthly." },
  "Commitments": { domain: "Commitment Decisions · reservations and savings plans", title: "Structure the <em>commitment</em> decision", why: "Commitment decisions made reactively or avoided entirely are where the most capital quietly erodes. The tradeoff between savings and flexibility should be modeled explicitly — not left to gut feel or default behavior.", move: "Before your next commitment decision, build a simple model that makes the tradeoff visible: savings captured, flexibility surrendered, risk assumed. Make the math legible to both finance and engineering." },
  "SaaS": { domain: "SaaS Governance · license and renewal discipline", title: "Audit the <em>quiet leak</em>", why: "SaaS sprawl is invisible until it isn't. Without a renewal cadence tied to real usage data, you're paying for seats no one touches and tools no one opens. This is one of the easiest costs to reclaim — and one of the easiest to ignore.", move: "Run a license audit this quarter. Flag anything under 60% utilized. Require a renewal justification before auto-renew — make the default skepticism, not continuation." },
  "Accountability": { domain: "Team-Level Accountability", title: "Make cost <em>visible</em> at the team level", why: "Pooled cost is invisible cost. Teams can't optimize spend they can't see, and finance can't hold anyone accountable without that visibility. Without team-level data, every cost conversation defaults to the same person doing the same analysis across the same opaque bill.", move: "Stand up showback reporting at the team level. Even if you're not ready for chargeback, visibility alone changes behavior. Start with your top three cost centers." },
  "Forecasting": { domain: "Cost Forecasting · confidence and accuracy", title: "Move from <em>guessing</em> to modeling", why: "Forecasts built on extrapolation break the moment growth patterns shift — which, in cloud and AI, is always. Modeled forecasts built on structured inputs hold up under change and create the conversation your leadership actually needs.", move: "Rebuild your next forecast with actual drivers: user growth, workload scaling assumptions, commitment changes, AI usage trajectory. Document the model so it can be updated, not redone." }
};

function setPriorityFocus() {
  const domainPcts = Object.keys(domains).map(key => {
    const qs = domains[key].questions.map(n => n - 1);
    const score = qs.reduce((s, qi) => s + (answers[qi]?.score || 0), 0);
    const max = qs.length * 3;
    return { key, pct: score / max, score, max };
  });
  domainPcts.sort((a, b) => a.pct - b.pct);
  const weakest = domainPcts[0].key;
  const action = priorityActions[weakest];
  if (!action) return;
  document.getElementById('priorityDomain').textContent = action.domain;
  document.getElementById('priorityTitle').innerHTML = action.title;
  document.getElementById('priorityWhy').textContent = action.why;
  document.getElementById('priorityMove').textContent = action.move;
}

let answers = {};
let currentQ = 0;

function buildQuestions() {
  const container = document.getElementById('questionsContainer');
  questions.forEach((q, i) => {
    const div = document.createElement('div');
    div.className = 'question-card' + (i === 0 ? ' active' : '');
    div.id = 'q-' + i;
    div.innerHTML = `
      <div class="q-number">0${q.id > 9 ? '' : ''}${q.id}</div>
      <div class="q-category">${q.category}</div>
      <div class="q-text">${q.text}</div>
      <div class="q-sub">${q.sub}</div>
      <div class="options">
        ${q.options.map((opt, oi) => `
          <button type="button" class="option" onclick="selectOption(${i}, ${oi}, ${opt.score})" id="opt-${i}-${oi}">
            <div class="option-marker"></div>
            <div class="option-text">${opt.text}</div>
          </button>
        `).join('')}
      </div>
      <div class="nav-buttons">
        <button type="button" class="btn btn-ghost" onclick="prevQuestion()" ${i === 0 ? 'style="visibility:hidden"' : ''}>← Previous</button>
        <button type="button" class="btn btn-primary" id="next-${i}" onclick="${i === questions.length-1 ? 'submitAudit()' : 'nextQuestion()'}" disabled>
          ${i === questions.length-1 ? 'Get My Diagnosis →' : 'Next →'}
        </button>
      </div>
    `;
    container.appendChild(div);
  });
}

function selectOption(qIdx, optIdx, score) {
  questions[qIdx].options.forEach((_, oi) => {
    document.getElementById(`opt-${qIdx}-${oi}`).classList.remove('selected');
  });
  document.getElementById(`opt-${qIdx}-${optIdx}`).classList.add('selected');
  answers[qIdx] = { optIdx, score, domain: questions[qIdx].domain };
  document.getElementById(`next-${qIdx}`).disabled = false;
}

function nextQuestion() {
  document.getElementById('q-' + currentQ).classList.remove('active');
  currentQ++;
  document.getElementById('q-' + currentQ).classList.add('active');
  updateProgress();
  smartScrollToCard();
}

function prevQuestion() {
  document.getElementById('q-' + currentQ).classList.remove('active');
  currentQ--;
  document.getElementById('q-' + currentQ).classList.add('active');
  updateProgress();
  smartScrollToCard();
}

function smartScrollToCard() {
  const card = document.getElementById('auditCard');
  const rect = card.getBoundingClientRect();
  if (rect.top < 0 || rect.top > window.innerHeight * 0.4) {
    card.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
}

function updateProgress() {
  const pct = ((currentQ) / questions.length) * 100;
  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('progressText').textContent = `${currentQ + 1} of ${questions.length}`;
}

async function submitAudit() {
  const totalScore = Object.values(answers).reduce((s, a) => s + a.score, 0);
  document.getElementById('auditCard').style.display = 'none';
  document.getElementById('progressWrap').style.display = 'none';
  document.getElementById('results').style.display = 'block';

  let tier, tierTitle, tierDesc;
  if (totalScore <= 12) {
    tier = 1; tierTitle = 'Signal <em>Lag</em>'; tierDesc = 'Level 01 · Signal Lag';
    document.getElementById('band1').classList.add('active');
  } else if (totalScore <= 24) {
    tier = 2; tierTitle = 'Signal <em>Transit</em>'; tierDesc = 'Level 02 · Signal Transit';
    document.getElementById('band2').classList.add('active');
  } else {
    tier = 3; tierTitle = 'Signal <em>Integration</em>'; tierDesc = 'Level 03 · Signal Integration';
    document.getElementById('band3').classList.add('active');
  }

  document.getElementById('tierLabel').textContent = tierDesc;
  document.getElementById('tierTitle').innerHTML = tierTitle;
  document.getElementById('scoreNum').textContent = totalScore;

  buildBreakdown(totalScore);
  setPriorityFocus();

  const answerSummary = questions.map((q, i) => {
    const ans = answers[i];
    return `Q${i+1} [${q.category}]: "${q.options[ans.optIdx].text}" (${ans.score}/3)`;
  }).join('\n');

  const tierName = tier === 1 ? 'Signal Lag' : tier === 2 ? 'Signal Transit' : 'Signal Integration';
  await fetchDiagnosis(totalScore, tierName, answerSummary);
}

function buildBreakdown(totalScore) {
  const grid = document.getElementById('breakdownGrid');
  const domainScores = {};
  Object.keys(domains).forEach(key => {
    const qs = domains[key].questions.map(n => n - 1);
    const score = qs.reduce((s, qi) => s + (answers[qi]?.score || 0), 0);
    const max = qs.length * 3;
    domainScores[key] = { score, max, pct: Math.round((score/max)*100) };
  });

  const groups = [
    { label: "Cost Signal Timing", keys: ["Timing"] },
    { label: "AI Governance", keys: ["AI Governance", "Detection"] },
    { label: "Accountability", keys: ["Accountability", "Commitments"] },
    { label: "Forecasting", keys: ["Forecasting"] },
    { label: "SaaS Governance", keys: ["SaaS"] },
    { label: "Finance–Engineering Alignment", keys: ["Alignment"] }
  ];

  groups.forEach(g => {
    const total = g.keys.reduce((s, k) => s + (domainScores[k]?.score || 0), 0);
    const max = g.keys.reduce((s, k) => s + (domainScores[k]?.max || 0), 0);
    const pct = Math.round((total/max)*100);
    const item = document.createElement('div');
    item.className = 'breakdown-item';
    item.innerHTML = `
      <div class="breakdown-item-label">${g.label}</div>
      <div class="breakdown-item-score">${total}<span style="font-size:16px;color:var(--text-light)">/${max}</span></div>
      <div class="breakdown-bar"><div class="breakdown-bar-fill" style="width:${pct}%"></div></div>
    `;
    grid.appendChild(item);
  });

  setTimeout(() => {
    document.querySelectorAll('.breakdown-bar-fill').forEach(bar => { bar.style.width = bar.style.width; });
  }, 100);
}

async function fetchDiagnosis(score, tierName, answerSummary) {
  const diagnosisEl = document.getElementById('diagnosisText');
  const loadingEl = document.getElementById('loadingIndicator');

  try {
    const response = await fetch('/api/signal-audit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ score, tier: tierName, answerSummary })
    });

    if (!response.ok) throw new Error('API error: ' + response.status);

    const data = await response.json();
    loadingEl.style.display = 'none';
    diagnosisEl.textContent = data.diagnosis || 'Unable to generate diagnosis at this time. Review your signal breakdown above for key areas of focus.';

  } catch (err) {
    loadingEl.style.display = 'none';
    diagnosisEl.textContent = 'Unable to generate diagnosis at this time. Your score has been recorded above — review your signal breakdown for key areas of focus.';
    console.error('API error:', err);
  }
}

function restartAudit() {
  answers = {};
  currentQ = 0;
  document.getElementById('results').style.display = 'none';
  document.getElementById('auditCard').style.display = 'block';
  document.getElementById('progressWrap').style.display = 'flex';
  document.getElementById('diagnosisText').innerHTML = '';
  document.getElementById('loadingIndicator').style.display = 'flex';
  document.getElementById('breakdownGrid').innerHTML = '';
  document.getElementById('band1').classList.remove('active');
  document.getElementById('band2').classList.remove('active');
  document.getElementById('band3').classList.remove('active');
  document.querySelectorAll('.question-card').forEach((card, i) => { card.classList.toggle('active', i === 0); });
  document.querySelectorAll('.option').forEach(opt => opt.classList.remove('selected'));
  document.querySelectorAll('[id^="next-"]').forEach(btn => btn.disabled = true);
  updateProgress();
}

buildQuestions();
updateProgress();
</script>

</BaseLayout>
